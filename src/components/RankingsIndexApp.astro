---
import { defaultLocale, type Locale } from '../config/site';
import { getLocalizedPath } from '../i18n/ui';
import { getRankingLabels, getRankingText } from '../i18n/rankingLabels';
import type { RankingData } from '../lib/eurovisionRankings';

interface Props {
  rankings: RankingData[];
  locale?: Locale;
}

const { rankings, locale = defaultLocale } = Astro.props;
const labels = getRankingLabels(locale);
---

<section class="rankings-index" aria-labelledby="rankings-title">
  <header class="hero-card rankings-hero">
    <div>
      <p class="eyebrow">{labels.eyebrow}</p>
      <h1 id="rankings-title">{labels.indexTitle}</h1>
      <p class="hero-copy">{labels.indexIntro}</p>
    </div>
  </header>

  <div class="rankings-grid">
    {rankings.map((ranking) => {
      const text = getRankingText(ranking.slug, locale);
      return (
        <a class="ranking-card" href={getLocalizedPath(`/rankings/${ranking.slug}/`, locale)}>
          <span>{labels.ranking}</span>
          <strong>{text.title}</strong>
          <p>{text.description}</p>
          <em>{labels.viewRanking}</em>
        </a>
      );
    })}
  </div>
</section>

<style>
  :global(.rankings-index) {
    display: grid;
    gap: 1rem;
    padding: 1.25rem 0 3rem;
  }

  :global(.rankings-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 0.85rem;
  }

  :global(.ranking-card) {
    display: grid;
    gap: 0.55rem;
    min-height: 13rem;
    border: 1px solid var(--color-border);
    border-radius: 1.35rem;
    background: color-mix(in srgb, var(--color-bg), var(--color-primary) 3%);
    color: var(--color-text);
    padding: 1rem;
    text-decoration: none;
    box-shadow: 0 14px 34px rgb(15 23 42 / 0.07);
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  :global(.ranking-card:hover) {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 30%);
    box-shadow: 0 18px 42px rgb(15 23 42 / 0.1);
  }

  :global(.ranking-card span),
  :global(.ranking-card em) {
    color: var(--color-muted);
    font-size: 0.76rem;
    font-style: normal;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  :global(.ranking-card strong) {
    font-size: 1.25rem;
    line-height: 1.1;
  }

  :global(.ranking-card p) {
    margin: 0;
    color: var(--color-muted);
    font-weight: 750;
  }

  :global(.ranking-card em) {
    align-self: end;
    color: var(--color-primary);
  }

  @media (min-width: 720px) {
    :global(.rankings-index) {
      gap: 1.35rem;
      padding-block: 2rem 4rem;
    }
  }
</style>
