---
import CountryProfileChart from './CountryProfileChart.astro';
import CountryProfileFaq from './CountryProfileFaq.astro';
import CountryProfileHistoryTable from './CountryProfileHistoryTable.astro';
import CountryProfileRelatedLinks from './CountryProfileRelatedLinks.astro';
import { getLocalizedPath, useTranslations } from '../i18n/ui';
import { defaultLocale, type Locale } from '../config/site';
import { getCountryProfileSeoLabels } from '../i18n/countryProfileSeoLabels';
import type { CountryProfile, CountryProfileSummary } from '../lib/eurovisionCountryProfiles';

interface Props {
  profile: CountryProfile;
  relatedCountries?: CountryProfileSummary[];
  locale?: Locale;
}

const { profile, relatedCountries = [], locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);
const seo = getCountryProfileSeoLabels(locale);
const countriesUrl = getLocalizedPath('/paises/', locale);
const comparatorUrl = getLocalizedPath('/comparador-paises/', locale);
const editionUrl = (year: number) => getLocalizedPath(`/ediciones/${year}/`, locale);
const missingValue = seo.dataEmptyTitle;
const formatValue = (value: number | string | null | undefined) => value ?? missingValue;
---

<article class="country-profile-app" aria-labelledby="country-profile-title">
  <header class="hero-card country-profile-hero">
    <div>
      <p class="eyebrow">{t('countryProfile.eyebrow')}</p>
      <h1 id="country-profile-title">
        {profile.flag && <img class="country-profile-flag" src={profile.flag} alt="" width="64" height="64" loading="eager" decoding="async" />}
        <span>{profile.country}: {t('countryProfile.titleSuffix')}</span>
      </h1>
      <p class="hero-copy">{t('countryProfile.description')}</p>
    </div>
    <nav class="history-actions" aria-label={seo.relatedTitle}>
      <a class="action-button action-button--primary" href={countriesUrl}>{seo.backToCountries}</a>
      <a class="action-button" href={comparatorUrl}>{seo.compareCountries}</a>
    </nav>
  </header>

  <section class="stats-card country-current-card" aria-labelledby="current-title">
    <p class="eyebrow"><a class="country-link edition-link" href={editionUrl(2026)}>Eurovision 2026</a></p>
    <h2 id="current-title">{t('countryProfile.currentTitle')}</h2>
    {profile.isCurrentParticipant ? (
      <div class="country-current-grid">
        {profile.currentEntries.map((entry) => (
          <article class="country-current-entry">
            <span class="result-badge result-badge--qualified">{entry.directFinalist ? t('countryProfile.directFinalist') : entry.contestName}</span>
            <h3>{entry.song}</h3>
            <p>{entry.artist}</p>
            {entry.runningOrder && <small>{t('countryProfile.runningOrder')}: {entry.runningOrder}</small>}
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state country-profile-empty">
        <span aria-hidden="true">🎤</span>
        <h3>{seo.currentEmptyTitle}</h3>
        <p>{seo.currentEmptyDescription}</p>
      </div>
    )}
  </section>

  <section class="stats-summary history-summary" aria-labelledby="country-stats-title">
    <h2 id="country-stats-title" class="visually-hidden">{t('countryProfile.statsTitle')}</h2>
    <div class="stats-kpi"><span>{t('countryProfile.participations')}</span><strong>{profile.participations}</strong></div>
    <div class="stats-kpi"><span>{t('countryProfile.wins')}</span><strong>{profile.wins}</strong></div>
    <div class="stats-kpi"><span>{t('countryProfile.averagePlace')}</span><strong>{formatValue(profile.averagePlace)}</strong></div>
    <div class="stats-kpi"><span>{t('countryProfile.bestPlace')}</span><strong>{formatValue(profile.bestPlace)}</strong></div>
    <div class="stats-kpi"><span>{t('countryProfile.averagePoints')}</span><strong>{formatValue(profile.averagePoints)}</strong></div>
    <div class="stats-kpi"><span>{t('countryProfile.totalPoints')}</span><strong>{profile.totalPoints.toLocaleString(locale)}</strong></div>
  </section>

  <CountryProfileChart entries={profile.history} locale={locale} />
  <CountryProfileHistoryTable entries={profile.history} locale={locale} />
  <CountryProfileRelatedLinks countries={relatedCountries} locale={locale} />
  <CountryProfileFaq country={profile.country} locale={locale} />
</article>

<style>
  :global(.country-profile-app) {
    display: grid;
    gap: 1rem;
    padding: 1.25rem 0 3rem;
  }

  :global(.country-profile-hero h1) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: 16ch;
  }

  :global(.country-profile-flag) {
    flex: 0 0 auto;
    width: clamp(3rem, 10vw, 4.5rem);
    height: clamp(2.1rem, 7vw, 3.15rem);
    border-radius: 0.75rem;
    object-fit: cover;
    box-shadow: 0 14px 34px rgb(15 23 42 / 0.16);
  }

  :global(.country-current-grid) {
    display: grid;
    gap: 0.75rem;
  }

  :global(.country-current-entry) {
    border: 1px solid var(--color-border);
    border-radius: 1.2rem;
    padding: 1rem;
    background: var(--color-bg);
  }

  :global(.country-current-entry h3),
  :global(.country-current-entry p) {
    margin: 0.35rem 0 0;
  }

  :global(.country-current-entry p),
  :global(.country-current-entry small) {
    color: var(--color-muted);
    font-weight: 800;
  }

  :global(.country-profile-empty) {
    justify-items: start;
    text-align: left;
  }

  @media (min-width: 720px) {
    :global(.country-profile-app) {
      gap: 1.35rem;
      padding-block: 2rem 4rem;
    }

    :global(.country-current-grid) {
      grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    }
  }
</style>
