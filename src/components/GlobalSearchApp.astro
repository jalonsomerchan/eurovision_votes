---
import { defaultLocale, type Locale } from '../config/site';
import { getSearchLabels } from '../i18n/searchLabels';
import type { SearchIndexItem, SearchResultType } from '../lib/searchIndex';

interface Props {
  index: SearchIndexItem[];
  locale?: Locale;
}

const { index, locale = defaultLocale } = Astro.props;
const labels = getSearchLabels(locale);
const grouped = index.slice(0, 24).reduce((acc, item) => {
  const group = acc.get(item.type) ?? [];
  group.push(item);
  acc.set(item.type, group);
  return acc;
}, new Map<SearchResultType, SearchIndexItem[]>());
const groupOrder: SearchResultType[] = ['country', 'edition', 'song', 'artist', 'tool'];
const searchScriptUrl = `${import.meta.env.BASE_URL}global-search.js?v=20260514-1`;
---

<section class="global-search" data-global-search aria-labelledby="global-search-title">
  <script type="application/json" data-search-index set:html={JSON.stringify(index)}></script>
  <script type="application/json" data-search-labels set:html={JSON.stringify(labels)}></script>

  <header class="hero-card global-search__hero">
    <p class="eyebrow">{labels.eyebrow}</p>
    <h1 id="global-search-title">{labels.title}</h1>
    <p class="hero-copy">{labels.intro}</p>
  </header>

  <form class="search-box" role="search" data-search-form>
    <label for="global-search-input">{labels.inputLabel}</label>
    <div class="search-box__row">
      <input
        id="global-search-input"
        name="q"
        type="search"
        autocomplete="off"
        inputmode="search"
        placeholder={labels.inputPlaceholder}
        aria-describedby="global-search-help global-search-status"
        data-search-input
      />
      <button type="button" data-search-clear>{labels.clear}</button>
    </div>
    <p id="global-search-help">{labels.help}</p>
    <p id="global-search-status" class="search-status" role="status" aria-live="polite" data-search-status></p>
  </form>

  <div class="search-state" data-search-initial>
    <strong>{labels.initialTitle}</strong>
    <p>{labels.initialCopy}</p>
  </div>

  <div class="search-state" data-search-empty hidden>
    <strong>{labels.emptyTitle}</strong>
    <p>{labels.emptyCopy}</p>
  </div>

  <div class="search-state search-state--error" data-search-error hidden>
    <strong>{labels.errorTitle}</strong>
    <p>{labels.errorCopy}</p>
  </div>

  <div class="search-results" data-search-results hidden></div>

  <noscript>
    <section class="search-results search-results--fallback" aria-labelledby="global-search-fallback-title">
      <h2 id="global-search-fallback-title">{labels.initialTitle}</h2>
      {groupOrder.map((type) => grouped.get(type)?.length ? (
        <section class="search-results__group">
          <h3>{labels.groups[type]}</h3>
          <ul>
            {grouped.get(type)?.map((item) => (
              <li>
                <a href={item.href}>{item.title}</a>
                <span>{item.description}</span>
              </li>
            ))}
          </ul>
        </section>
      ) : null)}
    </section>
  </noscript>
</section>

<script type="module" src={searchScriptUrl}></script>

<style>
  :global(.global-search) { display: grid; gap: 1rem; padding: 1.25rem 0 3rem; }
  :global(.global-search__hero h1) { max-width: 14ch; }
  :global(.search-box), :global(.search-state), :global(.search-results__group) { border: 1px solid var(--color-border); border-radius: 1.35rem; background: color-mix(in srgb, var(--color-bg), var(--color-primary) 3%); box-shadow: 0 14px 34px rgb(15 23 42 / 0.07); }
  :global(.search-box) { display: grid; gap: 0.75rem; padding: 1rem; }
  :global(.search-box label) { font-weight: 950; }
  :global(.search-box__row) { display: grid; gap: 0.65rem; }
  :global(.search-box input), :global(.search-box button) { width: 100%; min-height: 3rem; border: 1px solid var(--color-border); border-radius: 1rem; background: var(--color-bg); color: var(--color-text); padding: 0.8rem 0.95rem; font: inherit; }
  :global(.search-box input:focus), :global(.search-box button:focus-visible), :global(.search-result-card:focus-visible) { outline: 3px solid color-mix(in srgb, var(--color-primary), transparent 65%); outline-offset: 3px; }
  :global(.search-box button) { cursor: pointer; background: var(--color-primary); color: #fff; font-weight: 900; }
  :global(.search-box p), :global(.search-state p), :global(.search-result-card p), :global(.search-result-card span), :global(.search-results--fallback span) { margin: 0; color: var(--color-muted); font-weight: 750; }
  :global(.search-status) { min-height: 1.3rem; }
  :global(.search-state) { display: grid; gap: 0.35rem; padding: 1rem; }
  :global(.search-state[hidden]), :global(.search-results[hidden]) { display: none; }
  :global(.search-state strong) { font-size: 1.1rem; }
  :global(.search-state--error) { border-color: color-mix(in srgb, #ef4444, var(--color-border) 45%); }
  :global(.search-results) { display: grid; gap: 1rem; }
  :global(.search-results__group) { display: grid; gap: 0.75rem; padding: 1rem; }
  :global(.search-results__group h2), :global(.search-results__group h3) { margin: 0; font-size: 1.05rem; }
  :global(.search-results__grid) { display: grid; gap: 0.65rem; }
  :global(.search-result-card) { display: grid; gap: 0.35rem; border: 1px solid var(--color-border); border-radius: 1rem; background: var(--color-bg); color: var(--color-text); padding: 0.85rem; text-decoration: none; transition: transform 160ms ease, border-color 160ms ease; }
  :global(.search-result-card:hover) { transform: translateY(-1px); border-color: color-mix(in srgb, var(--color-primary), var(--color-border) 45%); }
  :global(.search-result-card strong) { font-size: 1.02rem; }
  :global(.search-result-card span) { font-size: 0.78rem; font-weight: 950; letter-spacing: 0.08em; text-transform: uppercase; }
  :global(.search-results--fallback ul) { display: grid; gap: 0.5rem; margin: 0; padding: 0; list-style: none; }
  :global(.search-results--fallback li) { display: grid; gap: 0.2rem; }
  :global(.search-results--fallback a) { color: var(--color-primary); font-weight: 900; }
  @media (min-width: 720px) {
    :global(.global-search) { gap: 1.25rem; padding-block: 2rem 4rem; }
    :global(.search-box__row) { grid-template-columns: minmax(0, 1fr) auto; }
    :global(.search-box button) { width: auto; }
    :global(.search-results__grid) { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 1040px) {
    :global(.search-results__grid) { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (prefers-color-scheme: dark) {
    :global(.search-box), :global(.search-state), :global(.search-results__group) { box-shadow: 0 18px 44px rgb(0 0 0 / 0.28); }
  }
</style>
