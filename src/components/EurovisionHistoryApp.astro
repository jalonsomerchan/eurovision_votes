---
import { getLocalizedPath } from '../i18n/ui';
import { defaultLocale, type Locale } from '../config/site';
import type { EurovisionHistoryData } from '../lib/eurovisionHistory';

interface Props {
  history: EurovisionHistoryData;
  locale?: Locale;
}

const { history, locale = defaultLocale } = Astro.props;
const contests = history.contests;
const firstYear = contests.at(-1)?.year;
const lastYear = contests[0]?.year;
const totalEntries = contests.reduce((sum, contest) => sum + contest.participants, 0);
const countries = new Set(contests.flatMap((contest) => contest.entries.map((entry) => entry.countryCode ?? entry.country)));
const latestContests = contests.slice(0, 8);
const homeUrl = getLocalizedPath('/', locale);
const voteUrl = getLocalizedPath('/vota/', locale);
const statsUrl = getLocalizedPath('/stats/', locale);
const editionUrl = (year: number) => getLocalizedPath(`/ediciones/${year}/`, locale);
const countryUrl = (countryCode?: string) => countryCode ? getLocalizedPath(`/paises/${countryCode.toLowerCase()}/`, locale) : '';
---

<section class="history-app" aria-labelledby="history-title">
  <script type="application/json" id="history-data" set:html={JSON.stringify(history)}></script>

  <div class="hero-card history-hero">
    <div>
      <p class="eyebrow">Resultados, ganadores y países</p>
      <h1 id="history-title">Histórico de Eurovision</h1>
      <p class="hero-copy">Consulta todas las ediciones de Eurovision con sus ganadores, sedes, canciones, artistas, países participantes, posiciones y puntos. Un recorrido completo por la historia del festival año a año.</p>
    </div>
    <div class="history-actions">
      <a class="action-button action-button--primary" href={voteUrl}>Votar Eurovision 2026</a>
      <a class="action-button" href={statsUrl}>Ver estadísticas</a>
      <a class="action-button" href={homeUrl}>Ir al inicio</a>
    </div>
  </div>

  {!history.datasetFound ? (
    <article class="empty-state">
      <span>🎤</span>
      <h2>Histórico no disponible</h2>
      <p>Ahora mismo no se pueden mostrar los resultados históricos de Eurovision. Vuelve a intentarlo más tarde.</p>
    </article>
  ) : (
    <>
      <div class="stats-summary history-summary" aria-label="Resumen del histórico de Eurovision">
        <div class="stats-kpi"><span>Ediciones</span><strong>{contests.length}</strong></div>
        <div class="stats-kpi"><span>Periodo</span><strong>{firstYear && lastYear ? `${firstYear}-${lastYear}` : '-'}</strong></div>
        <div class="stats-kpi"><span>Participaciones</span><strong>{totalEntries}</strong></div>
        <div class="stats-kpi"><span>Países</span><strong>{countries.size}</strong></div>
      </div>

      <section class="history-controls" aria-label="Filtros del histórico de Eurovision">
        <label>
          <span>Buscar</span>
          <input class="text-input" type="search" placeholder="País, artista, canción, ciudad..." data-history-search />
        </label>
        <label>
          <span>Desde</span>
          <select class="text-input" data-history-from>
            <option value="">Primer año</option>
            {contests.map((contest) => <option value={contest.year}>{contest.year}</option>)}
          </select>
        </label>
        <label>
          <span>Hasta</span>
          <select class="text-input" data-history-to>
            <option value="">Último año</option>
            {contests.map((contest) => <option value={contest.year}>{contest.year}</option>)}
          </select>
        </label>
        <label>
          <span>Orden</span>
          <select class="text-input" data-history-sort>
            <option value="desc">Más recientes primero</option>
            <option value="asc">Más antiguos primero</option>
          </select>
        </label>
      </section>

      <p class="feedback" data-history-status>{contests.length} ediciones cargadas.</p>

      <section class="stats-card" aria-labelledby="latest-winners-title">
        <p class="eyebrow">Ganadores de Eurovision</p>
        <h2 id="latest-winners-title">Últimos festivales</h2>
        <div class="history-winner-grid">
          {latestContests.map((contest) => (
            <article class="history-winner-card">
              <a class="country-link edition-link" href={editionUrl(contest.year)}>{contest.year}</a>
              <strong class="history-country-line">
                {contest.winnerFlag && <img class="history-flag" src={contest.winnerFlag} alt="" loading="lazy" decoding="async" width="64" height="64" />}
                {contest.winnerCode ? <a class="country-link" href={countryUrl(contest.winnerCode)}>{contest.winner || 'Sin ganador'}</a> : <span>{contest.winner || 'Sin ganador'}</span>}
              </strong>
              <p>{[contest.winnerArtist, contest.winnerSong].filter(Boolean).join(' - ') || 'Resultado pendiente'}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="history-timeline" data-history-list aria-live="polite"></section>
    </>
  )}
</section>
<script type="module" src="/history.js"></script>

<style>
  :global(.history-country-line),
  :global(.history-host-title) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
    vertical-align: middle;
  }

  :global(.history-country-line > span:last-child) {
    min-width: 0;
  }

  :global(.history-flag) {
    display: inline-block;
    flex: 0 0 auto;
    width: 1.85rem;
    height: 1.35rem;
    border-radius: 0.35rem;
    object-fit: cover;
    background: color-mix(in srgb, var(--color-border), transparent 42%);
    box-shadow: 0 6px 14px rgb(15 23 42 / 0.1);
  }

  :global(.history-contest-card h2 .history-flag) {
    margin-inline: 0.25rem 0.1rem;
    transform: translateY(0.08rem);
  }

  @media (max-width: 719px) {
    :global(.history-table-wrap) {
      border: 0;
      overflow: visible;
    }

    :global(.history-entry-table) {
      min-width: 0;
      border-collapse: separate;
      border-spacing: 0;
    }

    :global(.history-entry-table thead) {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
    }

    :global(.history-entry-table),
    :global(.history-entry-table tbody),
    :global(.history-entry-table tr),
    :global(.history-entry-table td) {
      display: block;
      width: 100%;
    }

    :global(.history-entry-table tr) {
      margin-bottom: 0.75rem;
      border: 1px solid var(--color-border);
      border-radius: 1rem;
      background: var(--color-bg);
      overflow: hidden;
    }

    :global(.history-entry-table td) {
      display: grid;
      grid-template-columns: minmax(6rem, 0.42fr) minmax(0, 1fr);
      gap: 0.75rem;
      align-items: center;
      border-bottom: 1px solid var(--color-border);
      padding: 0.75rem;
      text-align: left;
    }

    :global(.history-entry-table td:last-child) {
      border-bottom: 0;
    }

    :global(.history-entry-table td::before) {
      content: attr(data-label);
      color: var(--color-muted);
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  }
</style>
