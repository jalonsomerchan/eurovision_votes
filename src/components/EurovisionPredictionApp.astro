---
import { eurovision2026Contests } from '../config/eurovision2026';
import { defaultLocale, type Locale } from '../config/site';
import { getPredictionLabels } from '../i18n/predictionLabels';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const labels = getPredictionLabels(locale);
const candidates = eurovision2026Contests.flatMap((contest) => contest.songs).filter((song, index, songs) => (
  songs.findIndex((item) => item.flag === song.flag && item.country === song.country) === index
));
const predictionScriptUrl = `${import.meta.env.BASE_URL}prediction.js?v=20260513-1`;
---

<section class="prediction-app" aria-labelledby="prediction-title">
  <script type="application/json" id="prediction-candidates" set:html={JSON.stringify(candidates)}></script>
  <script type="application/json" id="prediction-labels" set:html={JSON.stringify(labels)}></script>

  <header class="hero-card prediction-hero">
    <div>
      <p class="eyebrow">{labels.eyebrow}</p>
      <h1 id="prediction-title">{labels.heading}</h1>
      <p class="hero-copy">{labels.copy}</p>
    </div>
    <div class="user-card" aria-live="polite">
      <span class="status-label">{labels.saveStatus}</span>
      <strong data-prediction-status>{labels.saved}</strong>
    </div>
  </header>

  <div class="prediction-grid">
    <section class="prediction-panel" aria-labelledby="prediction-winner-title">
      <h2 id="prediction-winner-title">{labels.winnerTitle}</h2>
      <label class="field-label" for="prediction-winner">{labels.winnerLabel}</label>
      <select id="prediction-winner" class="text-input" data-prediction-winner>
        <option value="">{labels.emptyOption}</option>
        {candidates.map((song) => <option value={song.flag}>{song.country} — {song.artist}</option>)}
      </select>
    </section>

    <section class="prediction-panel" aria-labelledby="prediction-share-title">
      <h2 id="prediction-share-title">{labels.shareTitle}</h2>
      <p>{labels.shareCopy}</p>
      <div class="prediction-actions">
        <button class="action-button action-button--primary" type="button" data-prediction-copy-link>{labels.copyLink}</button>
        <button class="action-button" type="button" data-prediction-copy-summary>{labels.copySummary}</button>
        <button class="action-button action-button--danger" type="button" data-prediction-reset>{labels.reset}</button>
      </div>
      <p class="feedback" role="status" aria-live="polite" data-prediction-feedback></p>
    </section>
  </div>

  <section class="prediction-panel" aria-labelledby="prediction-top-title">
    <div class="prediction-panel__head">
      <div>
        <h2 id="prediction-top-title">{labels.topTitle}</h2>
        <p>{labels.topCopy}</p>
      </div>
    </div>
    <div class="prediction-top-list" data-prediction-top-list>
      {Array.from({ length: 10 }, (_, index) => (
        <label class="prediction-position">
          <span>{labels.positionLabel.replaceAll('{position}', String(index + 1))}</span>
          <select class="text-input" data-prediction-position={index + 1}>
            <option value="">{labels.emptyOption}</option>
            {candidates.map((song) => <option value={song.flag}>{song.country} — {song.artist}</option>)}
          </select>
        </label>
      ))}
    </div>
  </section>

  <section class="prediction-preview" aria-live="polite" data-prediction-preview></section>
</section>

<script type="module" src={predictionScriptUrl}></script>
