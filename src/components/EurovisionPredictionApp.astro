---
import { eurovision2026Contests } from '../config/eurovision2026';
import { defaultLocale, type Locale } from '../config/site';
import { getPredictionLabels } from '../i18n/predictionLabels';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const labels = getPredictionLabels(locale);
const candidates = eurovision2026Contests.flatMap((contest) => contest.songs).filter((song, index, songs) => (
  songs.findIndex((item) => item.flag === song.flag && item.country === song.country) === index
));
const predictionScriptUrl = `${import.meta.env.BASE_URL}prediction.js?v=20260513-3`;
---

<section class="prediction-app" aria-labelledby="prediction-title">
  <script type="application/json" id="prediction-candidates" set:html={JSON.stringify(candidates)}></script>
  <script type="application/json" id="prediction-labels" set:html={JSON.stringify(labels)}></script>

  <header class="hero-card prediction-hero">
    <div>
      <p class="eyebrow">{labels.eyebrow}</p>
      <h1 id="prediction-title">{labels.heading}</h1>
      <p class="hero-copy">{labels.copy}</p>
    </div>
    <div class="user-card" aria-live="polite">
      <label class="field-label" for="prediction-name">{labels.nameLabel}</label>
      <input id="prediction-name" class="text-input" type="text" maxlength="40" autocomplete="name" placeholder={labels.namePlaceholder} data-prediction-name />
      <span class="status-label">{labels.saveStatus}</span>
      <strong data-prediction-status>{labels.saved}</strong>
    </div>
  </header>

  <div class="prediction-grid">
    <section class="prediction-panel" aria-labelledby="prediction-winner-title">
      <h2 id="prediction-winner-title">{labels.winnerTitle}</h2>
      <label class="field-label" for="prediction-winner">{labels.winnerLabel}</label>
      <select id="prediction-winner" class="text-input" data-prediction-winner>
        <option value="">{labels.emptyOption}</option>
        {candidates.map((song) => <option value={song.flag}>{song.country} — {song.artist}</option>)}
      </select>
    </section>

    <section class="prediction-panel" aria-labelledby="prediction-share-title">
      <h2 id="prediction-share-title">{labels.shareTitle}</h2>
      <p>{labels.shareCopy}</p>
      <div class="prediction-actions">
        <button class="action-button action-button--primary" type="button" data-prediction-copy-link>{labels.copyLink}</button>
        <button class="action-button" type="button" data-prediction-copy-summary>{labels.copySummary}</button>
        <button class="action-button" type="button" data-prediction-preview-image>{labels.previewImage}</button>
      </div>
      <p class="feedback" role="status" aria-live="polite" data-prediction-feedback></p>
    </section>
  </div>

  <section class="prediction-panel" aria-labelledby="prediction-top-title">
    <div class="prediction-panel__head">
      <div>
        <h2 id="prediction-top-title">{labels.topTitle}</h2>
        <p>{labels.topCopy}</p>
        <button class="action-button action-button--danger prediction-inline-reset" type="button" data-prediction-reset>{labels.reset}</button>
      </div>
      <strong class="prediction-active-slot" data-prediction-active-slot>{labels.selectedSlot.replaceAll('{position}', '1')}</strong>
    </div>
    <div class="prediction-slot-list" role="list" aria-label={labels.topTitle}>
      {Array.from({ length: 10 }, (_, index) => (
        <button class="prediction-slot" type="button" data-prediction-slot={index + 1} aria-pressed={index === 0 ? 'true' : 'false'}>
          <span>{index + 1}</span>
          <strong>{labels.emptyOption}</strong>
        </button>
      ))}
    </div>
    <div class="prediction-picker" aria-labelledby="prediction-picker-title">
      <div>
        <h3 id="prediction-picker-title">{labels.pickTitle}</h3>
        <p>{labels.pickCopy}</p>
      </div>
      <div class="prediction-country-grid" data-prediction-country-grid>
        {candidates.map((song) => (
          <button class="prediction-country-card" type="button" data-prediction-country={song.flag}>
            <img width="48" height="36" loading="lazy" alt={labels.flagAlt.replaceAll('{country}', song.country)} src={`https://flagsapi.com/${song.flag}/flat/64.png`} />
            <span>{song.country}</span>
            <small>{song.artist}</small>
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="prediction-preview" aria-live="polite" data-prediction-preview></section>

  <dialog class="prediction-modal" data-prediction-modal aria-labelledby="prediction-modal-title">
    <div class="prediction-modal__panel">
      <div class="prediction-modal__head">
        <h3 id="prediction-modal-title">{labels.previewTitle}</h3>
        <button class="action-button" type="button" data-prediction-close-modal>{labels.closePreview}</button>
      </div>
      <img class="prediction-modal__image" alt={labels.previewTitle} data-prediction-modal-image />
      <div class="prediction-actions">
        <button class="action-button action-button--primary" type="button" data-prediction-share-image>{labels.shareImage}</button>
        <button class="action-button" type="button" data-prediction-download-image>{labels.downloadImage}</button>
      </div>
    </div>
  </dialog>
</section>

<script type="module" src={predictionScriptUrl}></script>
