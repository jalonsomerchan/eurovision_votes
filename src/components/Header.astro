---
import Container from './Container.astro';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { getAlternateLocales, getLocalizedPath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const homeUrl = getLocalizedPath('/', locale);
const alternateLocales = getAlternateLocales(locale);
---

<header class="site-header">
  <Container class="flex items-center justify-between gap-3 py-4">
    <a class="font-bold tracking-tight" href={homeUrl}>{siteConfig.name}</a>
    <nav aria-label="Navegación principal" class="main-nav flex items-center gap-2 text-sm text-[var(--color-muted)]">
      <a class="hover:text-[var(--color-text)]" href={homeUrl}>{t('nav.home')}</a>
      <a class="hover:text-[var(--color-text)]" href="/stats/">Estadísticas</a>
      <details class="locale-menu">
        <summary>{localeLabels[locale]}</summary>
        <div class="locale-menu__list">
          {alternateLocales.map((alternateLocale) => (
            <a href={getLocalizedPath('/', alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
          ))}
        </div>
      </details>
      <button class="settings-trigger" type="button" data-open-settings>Ajustes</button>
    </nav>
  </Container>
</header>
