---
import Container from './Container.astro';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { getAlternateLocales, getLocalizedPath, useTranslations } from '../i18n/ui';
import { getNewsLabels } from '../i18n/newsLabels';
import { getRankingLabels } from '../i18n/rankingLabels';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const newsLabels = getNewsLabels(locale);
const rankingLabels = getRankingLabels(locale);
const homeUrl = getLocalizedPath('/', locale);
const voteUrl = getLocalizedPath('/vota/', locale);
const historyUrl = getLocalizedPath('/historico/', locale);
const countriesUrl = getLocalizedPath('/paises/', locale);
const newsUrl = getLocalizedPath('/noticias/', locale);
const rankingsUrl = getLocalizedPath('/rankings/', locale);
const countryPointsUrl = getLocalizedPath('/puntos-por-pais/', locale);
const statsUrl = getLocalizedPath('/stats/', locale);
const alternateLocales = getAlternateLocales(locale);
const currentPath = Astro.url.pathname;
const countryPathMatch = currentPath.match(/\/paises(?:\/([a-z0-9-]+))?\/?$/i);
const editionPathMatch = currentPath.match(/\/ediciones(?:\/(\d{4}))?\/?$/i);
const rankingPathMatch = currentPath.match(/\/rankings(?:\/([a-z0-9-]+))?\/?$/i);
const comparatorPathMatch = currentPath.match(/\/comparador-paises\/?$/i);
const alternatePath = currentPath.includes('/vota')
  ? '/vota/'
  : currentPath.includes('/puntos-por-pais')
    ? '/puntos-por-pais/'
    : currentPath.includes('/noticias')
      ? '/noticias/'
      : rankingPathMatch
        ? `/rankings/${rankingPathMatch[1] ? `${rankingPathMatch[1]}/` : ''}`
        : comparatorPathMatch
          ? '/comparador-paises/'
          : editionPathMatch
            ? `/ediciones/${editionPathMatch[1] ? `${editionPathMatch[1]}/` : ''}`
            : countryPathMatch
              ? `/paises/${countryPathMatch[1] ? `${countryPathMatch[1]}/` : ''}`
              : currentPath.includes('/historico')
                ? '/historico/'
                : currentPath.includes('/stats')
                  ? '/stats/'
                  : '/';
---

<header class="site-header app-header">
  <Container class="header-inner">
    <a class="site-brand" href={homeUrl} aria-label={siteConfig.name}>
      <span class="site-brand__mark">EV</span>
      <span class="site-brand__text">{siteConfig.name}</span>
    </a>

    <nav aria-label={t('nav.menu')} class="main-nav main-nav--desktop">
      <a href={homeUrl}>{t('nav.home')}</a>
      <a href={voteUrl}>{t('nav.vote')}</a>
      <a href={historyUrl}>{t('nav.history')}</a>
      <a href={countriesUrl}>{t('nav.countries')}</a>
      <a href={newsUrl}>{newsLabels.nav}</a>
      <a href={rankingsUrl}>{rankingLabels.ranking}</a>
      <a href={countryPointsUrl}>{t('nav.pointsByCountry')}</a>
      <a href={statsUrl}>{t('nav.stats')}</a>
      <details class="locale-menu">
        <summary>{localeLabels[locale]}</summary>
        <div class="locale-menu__list">
          {alternateLocales.map((alternateLocale) => (
            <a href={getLocalizedPath(alternatePath, alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
          ))}
        </div>
      </details>
      <button class="settings-trigger" type="button" data-open-settings>{t('nav.settings')}</button>
    </nav>

    <details class="mobile-menu" data-mobile-menu>
      <summary aria-label={t('nav.menu')} aria-controls="mobile-menu-panel">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div id="mobile-menu-panel" class="mobile-menu__panel">
        <div class="mobile-menu__head">
          <strong>{t('nav.menu')}</strong>
          <small>{localeLabels[locale]}</small>
        </div>
        <nav aria-label={t('nav.menu')} class="mobile-menu__nav">
          <a href={homeUrl}>{t('nav.home')}</a>
          <a href={voteUrl}>{t('nav.vote')}</a>
          <a href={historyUrl}>{t('nav.history')}</a>
          <a href={countriesUrl}>{t('nav.countries')}</a>
          <a href={newsUrl}>{newsLabels.nav}</a>
          <a href={rankingsUrl}>{rankingLabels.ranking}</a>
          <a href={countryPointsUrl}>{t('nav.pointsByCountry')}</a>
          <a href={statsUrl}>{t('nav.stats')}</a>
          <button type="button" data-open-settings>{t('nav.settings')}</button>
        </nav>
        <div class="mobile-menu__languages" aria-label={t('nav.language')}>
          <strong>{t('nav.language')}</strong>
          <div>
            {alternateLocales.map((alternateLocale) => (
              <a href={getLocalizedPath(alternatePath, alternateLocale)} hreflang={alternateLocale}>{localeLabels[alternateLocale]}</a>
            ))}
          </div>
        </div>
      </div>
    </details>
  </Container>
</header>

<script is:inline>
  document.addEventListener('click', (event) => {
    const mobileMenu = document.querySelector('[data-mobile-menu]');
    if (!mobileMenu?.open) return;

    const target = event.target;
    if (!(target instanceof Element)) return;

    const clickedInside = mobileMenu.contains(target);
    const clickedAction = target.closest('[data-open-settings], .mobile-menu__panel a');

    if (!clickedInside || clickedAction) {
      mobileMenu.open = false;
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    const mobileMenu = document.querySelector('[data-mobile-menu]');
    if (mobileMenu) mobileMenu.open = false;
  });
</script>
