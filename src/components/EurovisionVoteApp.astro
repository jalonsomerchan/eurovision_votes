---
import { defaultLocale, type Locale } from '../config/site';
import { eurovision2026Contests as contests } from '../config/eurovision2026';
import { getVoteLabels } from '../i18n/featureLabels';
import { getLocalizedPath } from '../i18n/ui';
import { getNavigationLabels } from '../i18n/navigationLabels';
import { getTopCardLabels } from '../i18n/topCardLabels';
import { getVoteShareLabels } from '../i18n/voteShareLabels';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const labels = getVoteLabels(locale);
const navLabels = getNavigationLabels(locale);
const topCardLabels = getTopCardLabels(locale);
const shareLabels = getVoteShareLabels(locale);
const statsUrl = getLocalizedPath('/stats/', locale);
const firebaseConfig = {
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY ?? '',
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN ?? '',
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID ?? '',
  storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET ?? '',
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID ?? '',
  appId: import.meta.env.PUBLIC_FIREBASE_APP_ID ?? '',
};
const voteScriptUrl = `${import.meta.env.BASE_URL}vote.js?v=20260514-6`;
---

<section class="eurovision-vote-app" aria-labelledby="vote-title">
  <script type="application/json" id="eurovision-contests" set:html={JSON.stringify(contests)}></script>
  <script type="application/json" id="firebase-config" set:html={JSON.stringify(firebaseConfig)}></script>
  <script type="application/json" id="vote-labels" set:html={JSON.stringify(labels)}></script>
  <script type="application/json" id="top-card-labels" set:html={JSON.stringify(topCardLabels)}></script>
  <script type="application/json" id="vote-share-labels" set:html={JSON.stringify(shareLabels)}></script>

  <header class="hero-card vote-hero">
    <p class="eyebrow">{labels.eyebrow}</p>
    <h1 id="vote-title">{labels.heading}</h1>
    <div class="vote-hero__grid">
      <div>
        <p class="hero-copy">{labels.copy}</p>
        <a class="action-button action-button--primary vote-stats-link" href={statsUrl}>{navLabels.voteStatsCta}</a>
      </div>
      <div class="user-card">
        <span class="status-label">{labels.profile}</span>
        <strong data-voter-name>{labels.guest}</strong>
        <button class="mini-button" type="button" data-open-name>{labels.changeName}</button>
      </div>
    </div>
  </header>

  <div class="tabs" role="tablist" aria-label={labels.tabsLabel} data-tabs></div>

  <div class="status-card" aria-live="polite">
    <div><span class="status-label">{labels.selectedShow}</span><strong data-active-name>Semifinal 1</strong></div>
    <div><span class="status-label">{labels.votedSongs}</span><strong data-voted-count>0/0</strong></div>
    <div><span class="status-label">{labels.saveStatus}</span><strong data-cloud-status>{labels.localSaved}</strong></div>
  </div>

  <p class="feedback" role="status" aria-live="polite" data-feedback></p>

  <div class="song-list" data-song-list></div>

  <section class="vote-share-card" aria-labelledby="vote-share-title" data-top-card-contest>
    <div>
      <p class="eyebrow">{shareLabels.eyebrow}</p>
      <h2 id="vote-share-title">{shareLabels.title}</h2>
      <p>{shareLabels.copy}</p>
    </div>
    <div class="vote-share-card__actions">
      <button class="action-button action-button--primary" type="button" data-share-vote-image data-top-card-download>{shareLabels.imageAction}</button>
      <button class="action-button" type="button" data-share-votes data-top-card-copy>{shareLabels.linkAction}</button>
    </div>
    <p class="feedback" role="status" aria-live="polite" data-vote-share-feedback></p>
  </section>

  <dialog class="vote-image-modal" data-vote-image-modal aria-labelledby="vote-image-modal-title">
    <div class="vote-image-modal__panel">
      <div class="vote-image-modal__head">
        <h2 id="vote-image-modal-title">{shareLabels.previewTitle}</h2>
        <button class="action-button" type="button" data-vote-image-close>{shareLabels.closePreview}</button>
      </div>
      <img class="vote-image-modal__image" alt={shareLabels.previewTitle} data-vote-image-preview />
      <div class="vote-share-card__actions">
        <button class="action-button action-button--primary" type="button" data-vote-image-share>{shareLabels.shareImage}</button>
        <button class="action-button" type="button" data-vote-image-download>{shareLabels.downloadImage}</button>
      </div>
    </div>
  </dialog>
</section>

<div class="app-modal" data-name-modal hidden>
  <div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="name-modal-title">
    <h2 id="name-modal-title">{labels.nameTitle}</h2>
    <p>{labels.nameCopy}</p>
    <form data-name-form>
      <label class="field-label" for="voter-name-input">{labels.nameLabel}</label>
      <input id="voter-name-input" class="text-input" name="name" autocomplete="name" maxlength="60" required />
      <div class="modal-actions"><button class="action-button action-button--primary" type="submit">{labels.saveName}</button></div>
    </form>
  </div>
</div>

<div class="app-modal" data-settings-modal hidden>
  <div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="settings-modal-title">
    <div class="modal-header-row">
      <div><p class="eyebrow">{labels.votesEyebrow}</p><h2 id="settings-modal-title">{labels.votesTitle}</h2></div>
      <button class="modal-close" type="button" data-close-settings aria-label={labels.closeSettings}>×</button>
    </div>
    <div class="settings-grid">
      <button class="action-button action-button--primary" type="button" data-export>{labels.exportVotes}</button>
      <label class="action-button" for="vote-import">{labels.importVotes}</label>
      <input id="vote-import" class="visually-hidden" type="file" accept="application/json,.json" data-import />
      <button class="action-button action-button--danger" type="button" data-reset>{labels.deleteVotes}</button>
    </div>
  </div>
</div>

<script type="module" src={voteScriptUrl}></script>

<style>
  :global(.vote-hero) { align-items: stretch; }
  :global(.vote-hero h1) { max-width: 15ch; }
  :global(.vote-hero__grid) { z-index: 1; display: grid; gap: 1rem; }
  :global(.vote-hero__grid .hero-copy) { margin-top: 0; }
  :global(.vote-share-card) { display: grid; gap: 1rem; border: 1px solid color-mix(in srgb, var(--color-border), transparent 12%); border-radius: 1.75rem; padding: 1rem; background: color-mix(in srgb, var(--color-bg), var(--color-primary) 4%); box-shadow: 0 20px 55px rgb(15 23 42 / 0.08); }
  :global(.vote-share-card h2), :global(.vote-share-card p) { margin: 0; }
  :global(.vote-share-card h2) { font-size: clamp(1.45rem, 5vw, 2.25rem); line-height: 1.05; letter-spacing: -0.05em; }
  :global(.vote-share-card p:not(.eyebrow):not(.feedback)) { color: var(--color-muted); font-weight: 750; }
  :global(.vote-share-card__actions) { display: grid; gap: 0.65rem; }
  :global(.vote-image-modal) { width: min(92vw, 42rem); border: 1px solid var(--color-border); border-radius: 1.4rem; padding: 0; background: var(--color-bg); color: var(--color-text); }
  :global(.vote-image-modal::backdrop) { background: rgb(10 6 24 / 0.72); }
  :global(.vote-image-modal__panel) { display: grid; gap: 1rem; padding: 1rem; }
  :global(.vote-image-modal__head) { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  :global(.vote-image-modal__head h2) { margin: 0; font-size: 1.2rem; }
  :global(.vote-image-modal__image) { width: 100%; height: auto; border-radius: 1rem; background: #160b2e; }
  @media (min-width: 720px) {
    :global(.vote-hero) { grid-template-columns: 1fr; }
    :global(.vote-hero__grid) { grid-template-columns: minmax(0, 1fr) minmax(16rem, 0.48fr); align-items: end; }
    :global(.vote-share-card) { grid-template-columns: minmax(0, 1fr) auto; align-items: center; padding: 1.2rem; }
    :global(.vote-share-card__actions) { display: flex; flex-wrap: wrap; justify-content: end; }
    :global(.vote-share-card .feedback) { grid-column: 1 / -1; }
    :global(.vote-image-modal__panel) { padding: 1.2rem; }
  }
  @media (prefers-color-scheme: dark) {
    :global(.vote-share-card) { box-shadow: 0 20px 55px rgb(0 0 0 / 0.28); }
  }
</style>
