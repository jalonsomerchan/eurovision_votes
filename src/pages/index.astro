---
import EurovisionHomeApp from '../components/EurovisionHomeApp.astro';
import Container from '../components/Container.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale } from '../config/site';
import { useTranslations } from '../i18n/ui';
import { getEurovisionEditions } from '../lib/eurovisionEditions';

const locale = defaultLocale;
const t = useTranslations(locale);
const editions = await getEurovisionEditions(locale);
const latestEdition = editions[0];
---

<BaseLayout title={t('home.title')} description={t('home.description')} locale={locale}>
  <Container>
    <EurovisionHomeApp latestEdition={latestEdition} locale={locale} />
  </Container>
</BaseLayout>
