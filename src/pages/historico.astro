---
import EurovisionHistoryApp from '../components/EurovisionHistoryApp.astro';
import Container from '../components/Container.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale } from '../config/site';
import { getEurovisionHistory } from '../lib/eurovisionHistory';

const history = await getEurovisionHistory(defaultLocale);
---

<BaseLayout title="Historico de Eurovision" description="Historico de festivales de Eurovision con ganadores, sedes, participantes, banderas y canciones." locale={defaultLocale}>
  <Container>
    <EurovisionHistoryApp history={history} locale={defaultLocale} />
  </Container>
</BaseLayout>
