---
import EurovisionHistoryApp from '../components/EurovisionHistoryApp.astro';
import Container from '../components/Container.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale } from '../config/site';
import { getEurovisionHistory } from '../lib/eurovisionHistory';

const history = await getEurovisionHistory(defaultLocale);
---

<BaseLayout title="Histórico de Eurovision: ganadores, resultados y países" description="Consulta el histórico completo de Eurovision con ganadores, sedes, países participantes, artistas, canciones, posiciones y puntos de cada edición." locale={defaultLocale}>
  <Container>
    <EurovisionHistoryApp history={history} locale={defaultLocale} />
  </Container>
</BaseLayout>
