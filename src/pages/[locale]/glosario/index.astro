---
import EurovisionGlossaryIndexApp from '../../../components/EurovisionGlossaryIndexApp.astro';
import Container from '../../../components/Container.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../../config/site';
import { listGlossaryTerms } from '../../../config/eurovisionGlossary';
import { getGlossaryLabels } from '../../../i18n/glossaryLabels';
import { isLocale } from '../../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const labels = getGlossaryLabels(locale);
const terms = listGlossaryTerms(locale);
---

<BaseLayout title={labels.indexTitle} description={labels.indexDescription} locale={locale}>
  <Container>
    <EurovisionGlossaryIndexApp terms={terms} locale={locale} />
  </Container>
</BaseLayout>
