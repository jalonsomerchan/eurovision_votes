---
import EurovisionCountryIndexApp from '../../../components/EurovisionCountryIndexApp.astro';
import Container from '../../../components/Container.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../../config/site';
import { isLocale, useTranslations } from '../../../i18n/ui';
import { listEurovisionCountryProfiles } from '../../../lib/eurovisionCountryProfiles';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
const countries = await listEurovisionCountryProfiles(locale);
---

<BaseLayout title={t('countryIndex.title')} description={t('countryIndex.description')} locale={locale}>
  <Container>
    <EurovisionCountryIndexApp countries={countries} locale={locale} />
  </Container>
</BaseLayout>
