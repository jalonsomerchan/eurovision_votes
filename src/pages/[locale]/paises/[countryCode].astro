---
import EurovisionCountryProfileApp from '../../../components/EurovisionCountryProfileApp.astro';
import Container from '../../../components/Container.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../../config/site';
import { isLocale } from '../../../i18n/ui';
import { formatCountryProfileLabel, getCountryProfileSeoLabels } from '../../../i18n/countryProfileSeoLabels';
import { getEurovisionCountryProfile, listEurovisionCountryCodes, listEurovisionCountryProfiles } from '../../../lib/eurovisionCountryProfiles';

export async function getStaticPaths() {
  const codes = await listEurovisionCountryCodes(defaultLocale);
  return locales
    .filter((locale) => locale !== defaultLocale)
    .flatMap((locale) => codes.map((countryCode) => ({ params: { locale, countryCode: countryCode.toLowerCase() } })));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const countryCode = String(Astro.params.countryCode ?? '').toUpperCase();
const profile = await getEurovisionCountryProfile(countryCode, locale);

if (!profile) {
  return Astro.redirect('/404/');
}

const labels = getCountryProfileSeoLabels(locale);
const countries = await listEurovisionCountryProfiles(locale);
const relatedCountries = countries
  .filter((country) => country.countryCode !== profile.countryCode)
  .sort((a, b) => b.participations - a.participations || a.country.localeCompare(b.country))
  .slice(0, 4);
const title = formatCountryProfileLabel(labels.title, profile.country);
const description = formatCountryProfileLabel(labels.description, profile.country);
---

<BaseLayout title={title} description={description} locale={locale}>
  <Container>
    <EurovisionCountryProfileApp profile={profile} relatedCountries={relatedCountries} locale={locale} />
  </Container>
</BaseLayout>
