---
import EurovisionHomeApp from '../../components/EurovisionHomeApp.astro';
import Container from '../../components/Container.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';
import { getEurovisionEditions } from '../../lib/eurovisionEditions';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({
      params: { locale },
    }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
const editions = await getEurovisionEditions(locale);
const latestEdition = editions[0];
---

<BaseLayout title={t('home.title')} description={t('home.description')} locale={locale}>
  <Container>
    <EurovisionHomeApp latestEdition={latestEdition} locale={locale} />
  </Container>
</BaseLayout>
