---
import EurovisionTimelineApp from '../../../components/EurovisionTimelineApp.astro';
import Container from '../../../components/Container.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../../config/site';
import { isLocale } from '../../../i18n/ui';
import { getTimelineLabels } from '../../../i18n/timelineLabels';
import { getEurovisionTimeline } from '../../../lib/eurovisionTimeline';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const labels = getTimelineLabels(locale);
const timeline = await getEurovisionTimeline(locale);
---

<BaseLayout title={labels.title} description={labels.description} locale={locale}>
  <Container>
    <EurovisionTimelineApp timeline={timeline} locale={locale} />
  </Container>
</BaseLayout>
