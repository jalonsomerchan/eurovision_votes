---
import EurovisionNewsApp from '../../../components/EurovisionNewsApp.astro';
import Container from '../../../components/Container.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../../config/site';
import { isLocale } from '../../../i18n/ui';
import { getNewsLabels } from '../../../i18n/newsLabels';
import { getEscplusNewsFeed } from '../../../lib/newsFeed.mjs';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const labels = getNewsLabels(locale);
const feed = await getEscplusNewsFeed();
---

<BaseLayout title={labels.title} description={labels.description} locale={locale}>
  <Container>
    <EurovisionNewsApp items={feed.items} error={feed.error} sourceUrl={feed.sourceUrl} locale={locale} />
  </Container>
</BaseLayout>
