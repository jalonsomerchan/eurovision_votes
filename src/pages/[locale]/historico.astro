---
import EurovisionHistoryApp from '../../components/EurovisionHistoryApp.astro';
import Container from '../../components/Container.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../config/site';
import { isLocale } from '../../i18n/ui';
import { getEurovisionHistory } from '../../lib/eurovisionHistory';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const history = await getEurovisionHistory(locale);
---

<BaseLayout title="Histórico de Eurovision: ganadores, resultados y países" description="Consulta el histórico completo de Eurovision con ganadores, sedes, países participantes, artistas, canciones, posiciones y puntos de cada edición." locale={locale}>
  <Container>
    <EurovisionHistoryApp history={history} locale={locale} />
  </Container>
</BaseLayout>
