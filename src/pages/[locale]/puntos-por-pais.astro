---
import EurovisionCountryPointsApp from '../../components/EurovisionCountryPointsApp.astro';
import Container from '../../components/Container.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../config/site';
import { isLocale, useTranslations } from '../../i18n/ui';
import { getEurovisionCountryPoints } from '../../lib/eurovisionCountryPoints';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
const data = await getEurovisionCountryPoints(locale);
---

<BaseLayout title={t('countryPoints.title')} description={t('countryPoints.description')} locale={locale}>
  <Container>
    <EurovisionCountryPointsApp data={data} locale={locale} />
  </Container>
</BaseLayout>
