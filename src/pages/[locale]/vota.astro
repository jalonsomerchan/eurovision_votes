---
import EurovisionVoteApp from '../../components/EurovisionVoteApp.astro';
import Container from '../../components/Container.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../config/site';
import { isLocale } from '../../i18n/ui';
import { getVotePageSeoLabels } from '../../i18n/votePageSeoLabels';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const seo = getVotePageSeoLabels(locale);
---

<BaseLayout title={seo.title} description={seo.description} locale={locale}>
  <Container>
    <EurovisionVoteApp locale={locale} />
  </Container>
</BaseLayout>
