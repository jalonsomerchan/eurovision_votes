---
import EurovisionCountryMapApp from '../../../components/EurovisionCountryMapApp.astro';
import Container from '../../../components/Container.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLocale, locales, type Locale } from '../../../config/site';
import { isLocale } from '../../../i18n/ui';
import { getMapLabels } from '../../../i18n/mapLabels';
import { getEurovisionMapCountries } from '../../../lib/eurovisionMapData';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const labels = getMapLabels(locale);
const countries = await getEurovisionMapCountries(locale);
---

<BaseLayout title={labels.title} description={labels.description} locale={locale}>
  <Container>
    <EurovisionCountryMapApp countries={countries} locale={locale} />
  </Container>
</BaseLayout>
