# Override the default GitHub Pages site URL if needed.
ASTRO_SITE=https://usuario.github.io

# Override the generated base path if the project is deployed under a subfolder.
ASTRO_BASE=/nombre-repo

# Firebase web app config.
# In GitHub Pages, add these in Settings > Secrets and variables > Actions.
# They can be Repository variables or Repository secrets.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
